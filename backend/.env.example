# Claude API Key（必填）
ANTHROPIC_API_KEY=sk-your-key-here

# AI 模型（可选）
ANTHROPIC_MODEL=claude-sonnet-4-6

# 数据库（可选，默认 SQLite）
# SQLite: sqlite:///./interview.db
# PostgreSQL: postgresql://user:password@localhost:5432/interview
DATABASE_URL=sqlite:///./interview.db

# PostgreSQL 连接池（可选）
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
